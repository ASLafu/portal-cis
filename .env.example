# ============================================================
#  CIS API – Variables de entorno (PLANTILLA)
#  Copia este archivo como .env y rellena los valores reales.
#  NUNCA subas el .env real a GitHub.
# ============================================================

# Puerto de la API
PORT=3001

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cis_madrid

# Origen permitido para CORS (URL del frontend)
CORS_ORIGIN=http://localhost

# Código de acceso exclusivo para el registro de profesionales
CODIGO_PROFESIONAL=CAMBIA_ESTO_POR_UN_CODIGO_SEGURO

# ── Configuración de email (Gmail SMTP) ──────────────────────
# Necesitas una "Contraseña de aplicación" de Google, no tu contraseña normal.
# Cómo obtenerla: myaccount.google.com → Seguridad → Verificación en 2 pasos → Contraseñas de aplicación
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=tu_contrasena_de_aplicacion_de_16_caracteres
EMAIL_FROM=CIS Madrid <tucorreo@gmail.com>

# URL base del frontend (para los enlaces dentro de los emails)
APP_URL=http://localhost:3001
