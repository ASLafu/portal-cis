# ============================================================
#  CIS API – Variables de entorno (Plantilla)
#
#  INSTRUCCIONES PARA RAILWAY:
#  Railway asigna automáticamente estas variables cuando agregas MySQL:
#  - MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE
#
#  Para desarrollo local:
#  1. Copia este archivo como .env en la carpeta /api
#  2. Rellena los valores reales
#  3. NUNCA hagas commit de .env a Git (está en .gitignore)
# ============================================================

# Puerto de la API
# En Railway: se asigna automáticamente
PORT=3001

# ── BASE DE DATOS MySQL ──────────────────────────────────
# En Railway: estas variables se asignan automáticamente
# En desarrollo local: configura XAMPP
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cis_madrid

# ── CORS (URL del frontend) ──────────────────────────────
# En Railway: https://tu-proyecto.up.railway.app
CORS_ORIGIN=http://localhost

# ── EMAIL (Gmail SMTP) ───────────────────────────────────
# IMPORTANTE: Usa "Contraseña de aplicación" si tienes 2FA en Gmail
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=cismadrid23@gmail.com
SMTP_PASS=tu_contrasena_aqui

# ── SEGURIDAD ────────────────────────────────────────────
# Código de acceso para registro de profesionales
# CÁMBIALO por uno único y seguro antes de producción
CODIGO_PROFESIONAL=CIS-PRO-2026

# ── APP URL ──────────────────────────────────────────────
# URL base para los enlaces de email (consentimientos, etc)
# En Railway: https://tu-proyecto.up.railway.app
APP_URL=http://localhost:3001
EMAIL_FROM=CIS Madrid <cismadrid23@gmail.com>
